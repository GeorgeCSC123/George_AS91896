user_answers = {}
first_question = 0

# function questions page
def questions_page():
  global first_question
  clear_window()

# current question number
  quest = quiz_info[first_question]

# keep track of option buttons
  all_buttons = []

# function select option effect stay
  def select_option(selected_option, clicked_button):
      user_answers[first_question] = selected_option

      for btn in all_buttons:
          btn.config(bg="white", fg="#db2e2e")

      clicked_button.config(bg="#cb6ce6", fg="white")

# function next, back and skip button
  def next_question():
      global first_question
      if first_question < len(quiz_info) - 1:
          first_question += 1
          questions_page()
      else:
          score_page()

  def back_question():
      global first_question
      first_question -= 1
      questions_page()

  def skip_question():
      global first_question
      if first_question < len(quiz_info) - 1:
          first_question += 1
          questions_page()
      else:
          score_page()

# question number indicator
  question_number_label = tk.Label(root, text=f"Question {first_question + 1} / 10", padx=15, bg="white", pady=10, font=("Arial", 20, "bold"), )
  question_number_label.pack(pady=15)

# question label
  question_label = tk.Label(root, text=quest["question"], font=("Arial", 25, "bold"), bg="#7ed957", fg="#cb6ce6")
  question_label.pack(pady=10)

# question image and resizing
  from PIL import Image, ImageTk
  img = Image.open(quest["image"])
  width, height = img.size
  img = img.resize((int(width * 1.5), int(height * 1.5)))
  question_image = ImageTk.PhotoImage(img)
  image_label = tk.Label(root, image=question_image, bg="#7ed957")
  image_label.image = question_image
  image_label.pack(pady=5)

# Option buttons
  row1 = tk.Frame(root, bg="#7ed957")
  row2 = tk.Frame(root, bg="#7ed957")
  row1.pack()
  row2.pack()

# Row 1 two options
  for option in quest["option"][:2]:
      border = tk.Frame(row1, bg="#cb6ce6", padx=2, pady=2)
      button = tk.Button(border, text=option, font=("Arial", 15, "bold"), width=11, height=2, fg="#db2e2e", bg="white")
      button.config(command=lambda o=option, b=button: select_option(o, b))
      button.pack()
      border.pack(side="left", padx=15, pady=15)
      all_buttons.append(button)

# Row 2 two options
  for option in quest["option"][2:]:
      border = tk.Frame(row2, bg="#cb6ce6", padx=2, pady=2)
      button = tk.Button(border, text=option, font=("Arial", 15, "bold"), width=11, height=2, fg="#db2e2e", bg="white")
      button.config(command=lambda o=option, b=button: select_option(o, b))
      button.pack()
      border.pack(side="left", padx=15, pady=15)
      all_buttons.append(button)

# navigation buttons
  back_button = tk.Button(root, image=nav1, command=back_question, bd=0, relief="flat", highlightthickness=0,
                       bg="#7ed957",activebackground="#7ed957", cursor="hand2")
  back_button.place(relx=0.02, rely=0.95, anchor="sw")

  next_button = tk.Button(root, image=nav2, command=next_question, bd=0, relief="flat", highlightthickness=0,
                       bg="#7ed957",activebackground="#7ed957", cursor="hand2")
  next_button.place(relx=0.98, rely=0.95, anchor="se")

  skip_button = tk.Button(root, image=nav3, command=skip_question, bd=0, relief="flat", highlightthickness=0,
                       bg="#7ed957",activebackground="#7ed957", cursor="hand2")
  skip_button.place(relx=0.98, rely=0.825, anchor="se")

